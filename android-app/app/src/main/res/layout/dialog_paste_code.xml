<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/paste_code"
        android:textSize="@dimen/text_title"
        android:textColor="@color/ink"
        android:layout_marginBottom="@dimen/space_xs" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paste the invite JSON from the family creator"
        android:textSize="@dimen/text_body"
        android:textColor="@color/muted"
        android:layout_marginBottom="@dimen/space_md" />

    <EditText
        android:id="@+id/inviteCodeInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:background="@drawable/bg_input_selector"
        android:padding="@dimen/space_md"
        android:textSize="@dimen/text_small"
        android:textColor="@color/ink"
        android:textColorHint="@color/border_strong"
        android:hint="@string/paste_invite_hint"
        android:inputType="textMultiLine"
        android:gravity="top"
        android:fontFamily="monospace"
        android:importantForAutofill="no" />
</LinearLayout>
