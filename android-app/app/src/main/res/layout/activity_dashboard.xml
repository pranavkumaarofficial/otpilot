<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_soft">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_md"
        android:background="@color/canvas"
        android:elevation="0dp">

        <!-- Title section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="@dimen/text_title"
                android:textColor="@color/ink"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/familyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_small"
                android:textColor="@color/muted" />
        </LinearLayout>

        <!-- Connection dot -->
        <View
            android:id="@+id/connDot"
            android:layout_width="@dimen/conn_dot_size"
            android:layout_height="@dimen/conn_dot_size"
            android:background="@drawable/dot_disconnected"
            android:layout_marginEnd="@dimen/space_sm" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/settingsBtn"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings"
            android:scaleType="center" />
    </LinearLayout>

    <!-- Hairline below topbar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hairline" />

    <!-- Tab bar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tabsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_md"
        android:paddingVertical="@dimen/space_sm"
        android:background="@color/canvas"
        android:clipToPadding="false" />

    <!-- Hairline below tabs -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hairline" />

    <!-- OTP feed -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/otpFeed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/space_md"
            android:clipToPadding="false" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/space_xxl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_otps_title"
                android:textSize="@dimen/text_button"
                android:textColor="@color/ink"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="@dimen/space_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_otps_body"
                android:textSize="@dimen/text_body"
                android:textColor="@color/muted"
                android:gravity="center" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/testOtpBtn"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/space_lg"
                android:paddingHorizontal="@dimen/space_lg"
                android:text="@string/send_test_otp"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_body"
                android:background="@drawable/bg_btn_primary"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
