<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/space_lg">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_title"
            android:textSize="@dimen/text_display"
            android:textColor="@color/ink"
            android:fontFamily="sans-serif"
            android:textStyle="normal"
            android:layout_marginBottom="@dimen/space_xs" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_subtitle"
            android:textSize="@dimen/text_body"
            android:textColor="@color/muted"
            android:gravity="center"
            android:layout_marginBottom="@dimen/space_xxl" />

        <!-- Name input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enter_name"
            android:textSize="@dimen/text_body"
            android:textColor="@color/body"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/space_xs" />

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/bg_input_selector"
            android:paddingHorizontal="@dimen/space_md"
            android:textSize="@dimen/text_body"
            android:textColor="@color/ink"
            android:textColorHint="@color/border_strong"
            android:hint="@string/name_hint"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:importantForAutofill="no"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- Scan QR button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/scanBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/scan_qr"
            android:textColor="@color/on_primary"
            android:textSize="@dimen/text_button"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:paddingVertical="@dimen/space_md"
            android:paddingHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_md" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_md">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/hairline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/or_divider"
                android:textSize="@dimen/text_body"
                android:textColor="@color/muted"
                android:paddingHorizontal="@dimen/space_md" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/hairline" />
        </LinearLayout>

        <!-- Paste code button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/pasteBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_secondary"
            android:text="@string/paste_code"
            android:textColor="@color/ink"
            android:textSize="@dimen/text_button"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:paddingVertical="@dimen/space_md"
            android:paddingHorizontal="@dimen/space_lg" />

        <!-- Status text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textColor="@color/muted"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_lg"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>
